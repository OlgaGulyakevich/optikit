{
  "name": "@gulyakevich/optikit",
  "version": "0.1.0",
  "description": "CLI utility to optimize web assets — images, video, og-image, favicon, svg.",
  "type": "module",
  "bin": {
    "optikit": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "cli",
    "image-optimization",
    "video",
    "favicon",
    "svg",
    "sharp",
    "ffmpeg",
    "webp",
    "avif"
  ],
  "author": "Olga Gulyakevich",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2",
    "svgo": "^4.0.1",
    "tinyglobby": "^0.2.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
